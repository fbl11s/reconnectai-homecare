{
  "version": 2,
  "builds": [
    {
      "src": "api/telegram-webhook.py",
      "use": "@vercel/python",
      "config": {
        "entrypoint": "api/telegram-webhook:app"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/telegram-webhook",
      "dest": "api/telegram-webhook.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
